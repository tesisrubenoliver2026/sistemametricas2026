{
  "name": "migracion_cliente",
  "private": true,
  "version": "1.0.0",
  "description": "Sistema de Ventas - Cliente de Escritorio",
  "author": "Tu Empresa",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "electron": "electron .",
    "electron:dev": "vite & electron .",
    "dist": "npm run build && electron-builder --win --x64"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.4",
    "@heroicons/react": "^2.2.0",
    "@internationalized/date": "^3.10.1",
    "@react-aria/i18n": "^3.12.14",
    "@tailwindcss/vite": "^4.1.11",
    "axios": "^1.10.0",
    "clsx": "^2.1.1",
    "flowbite": "^4.0.1",
    "flowbite-datepicker": "^2.0.0",
    "framer-motion": "^12.23.24",
    "i18next": "^25.8.0",
    "libphonenumber-js": "^1.12.25",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-apexcharts": "^1.7.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.66.0",
    "react-i18next": "^16.5.3",
    "react-icons": "^5.5.0",
    "react-international-phone": "^4.6.0",
    "react-jvectormap": "^0.0.15",
    "react-number-format": "^5.4.4",
    "react-phone-number-input": "^3.4.13",
    "react-router-dom": "^7.7.0",
    "react-tailwindcss-datepicker": "^2.0.0",
    "recharts": "^3.3.0",
    "tailwind-datepicker-react": "^1.4.3",
    "tailwindcss": "^4.1.11",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.15",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "i18next-parser": "^9.0.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vite-plugin-pages": "^0.33.1"
  },
  "build": {
    "appId": "com.tuempresa.tuapp",
    "productName": "MigracionCliente",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
